            {
              "id": "7a24a738-0440-4628-b909-10b8c343e8aa",
              "name": "Message_text",
              "value": "={{ \"La siguiente descripción es una IMAGEN que el usuario compartió: \" + $json.image.caption }} {{ $json.text }}\n",
              "type": "string"
            },
            {
              "id": "47cab13e-276e-4ab2-9d02-ee40a292a235",
              "name": "From",
              "value": "={{ $('Webhook').item.json.body.data.key.remoteJid.replace('@s.whatsapp.net', '') }}",
              "type": "string"
            },
